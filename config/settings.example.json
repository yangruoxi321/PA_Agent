{
  "provider": {
    "model": "deepseek-chat",
    "base_url": "https://api.deepseek.com",
    "api_format": "openai",
    "api_key_encrypted": "",
    "thinking": true,
    "reasoning_effort": "high",
    "context_window": 128000
  },
  "general": {
    "analysis_bar_count": 100,
    "refresh_interval_ms": 1000,
    "context_warning_threshold_pct": 80.0,
    "last_data_source": "mt5",
    "last_tradingview_exchange": "OANDA",
    "last_symbol": "XAUUSDm",
    "last_timeframe": "15m",
    "decision_flow_auto_play": true,
    "decision_flow_play_seconds": 50,
    "incremental_max_new_bars": 10,
    "decision_stance": "balanced",
    "decision_flow_default_zoom_pct": 500,
    "stream_pane_font_pt": 11,
    "chart_seq_label_font_pt": 7,
    "auto_resume_chart_after_analysis": true
  },
  "prompt": {
    "stage2_load_full_strategy_library": false,
    "experience_max_entries": 3,
    "experience_max_chars_per_entry": 400,
    "stage1_inject_pattern_briefs": true
  },
  "validation": {
    "normalization_mode": "strict",
    "trace_semantic_checks": true,
    "strict_bar_by_bar_features": true,
    "disable_truncation_repair": true
  },
  "feishu": {
    "enabled": true,
    "webhook_url": "",
    "secret": "",
    "app_id": "",
    "app_secret": "",
    "notify_on_order_only": true
  }
}
